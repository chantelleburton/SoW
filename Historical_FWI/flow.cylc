[scheduler]
    allow implicit tasks = True

[task parameters]
    
    member = 1..15

[scheduling]

    [[graph]]
        R1 = """
            hadgem_historical_fwi<member>
        """

[runtime]
    [[hadgem_historical_fwi<member>]]
        script = """
        set -eux
        conda activate sowf
        cd /data/users/bob.potts/StateOfFires_2025-26/code/Historical_FWI/
        python HadGEM3_Historical_FWI.py
        """

        platform = spice

        [[[directives]]]
            --mem = 60G
            --time = 120
            --cpus-per-task = 1
            --ntasks = 1